{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automaniaai.com.br/fabio/schemas/mod-02/activity-list.schema.json",
  "title": "Module 02 Activity List Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "minLength": 1 },
        "source_module": {
          "type": "string",
          "enum": ["mod-01-owner-concierge", "mod-02-whatsapp-crm"]
        },
        "correlation_id": { "type": "string", "format": "uuid" },
        "filters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "deal_id": { "type": "string", "format": "uuid" },
            "contact_id": { "type": "string", "format": "uuid" },
            "kind": { "type": "string", "enum": ["note", "task", "message", "call", "meeting", "system"] },
            "since": { "type": "string", "format": "date-time" }
          }
        },
        "pagination": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "limit": { "type": "integer", "minimum": 1, "maximum": 500 },
            "offset": { "type": "integer", "minimum": 0 }
          }
        }
      },
      "required": ["request_id", "tenant_id", "source_module"]
    }
  },
  "required": ["request"]
}
