{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automaniaai.com.br/fabio/schemas/mod-02/contact-create.schema.json",
  "title": "Module 02 Contact Create Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": { "type": "string", "format": "uuid" },
        "tenant_id": { "type": "string", "minLength": 1 },
        "source_module": {
          "type": "string",
          "enum": ["mod-01-owner-concierge", "mod-02-whatsapp-crm", "mod-03-clientes"]
        },
        "correlation_id": { "type": "string", "format": "uuid" },
        "contact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "contact_id": { "type": "string", "format": "uuid" },
            "account_id": { "type": "string", "format": "uuid" },
            "external_key": { "type": "string", "minLength": 3 },
            "display_name": { "type": "string", "minLength": 2 },
            "job_title": { "type": "string", "minLength": 2 },
            "phone_e164": { "type": "string", "pattern": "^\\+[1-9][0-9]{7,14}$" },
            "email": { "type": "string", "format": "email" },
            "status": { "type": "string", "enum": ["active", "inactive"] },
            "metadata": { "type": "object" }
          },
          "required": ["display_name"]
        }
      },
      "required": ["request_id", "tenant_id", "source_module", "contact"]
    }
  },
  "required": ["request"]
}
