{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://automaniaai.com.br/fabio/schemas/mod-02/conversation-list.schema.json",
  "title": "Module 02 CRM Conversation List Contract",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "count": { "type": "integer", "minimum": 0 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "conversation_id": { "type": "string", "format": "uuid" },
          "tenant_id": { "type": "string", "minLength": 1 },
          "contact_e164": { "type": "string", "pattern": "^\\+[1-9][0-9]{7,14}$" },
          "display_name": { "type": ["string", "null"] },
          "lead_id": { "type": ["string", "null"], "format": "uuid" },
          "lead_stage": {
            "type": ["string", "null"],
            "enum": [
              "new",
              "contacted",
              "qualified",
              "proposal",
              "negotiation",
              "won",
              "lost",
              "nurturing",
              "disqualified",
              null
            ]
          },
          "last_message_preview": { "type": "string" },
          "last_message_at": { "type": ["string", "null"], "format": "date-time" },
          "unread_count": { "type": "integer", "minimum": 0 },
          "metadata": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "required": [
          "conversation_id",
          "tenant_id",
          "contact_e164",
          "last_message_preview",
          "unread_count",
          "metadata",
          "created_at",
          "updated_at"
        ]
      }
    }
  },
  "required": ["tenant_id", "count", "items"]
}
