{
  "name": "app-platform-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/platform-api/src",
  "projectType": "application",
  "tags": ["scope:app", "domain:api"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx run app-owner-console:build",
          "npx nx run app-crm-console:build",
          "node tools/build-platform-api.mjs --owner dist/apps/owner-console --crm dist/apps/crm-console --out dist/apps/platform-api"
        ]
      },
      "outputs": ["{workspaceRoot}/dist/apps/platform-api"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/platform-api/src/server.mjs"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test --test-concurrency=1 apps/platform-api/src/*.test.mjs"
      }
    }
  }
}
